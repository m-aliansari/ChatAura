{
    "name": "@realtime-chatapp/server",
    "version": "1.0.0",
    "main": "index.ts",
    "license": "MIT",
    "type": "module",
    "dependencies": {
        "@realtime-chatapp/common": "1.0.0",
        "bcrypt": "^6.0.0",
        "cors": "^2.8.5",
        "dotenv": "^17.2.0",
        "express": "^5.1.0",
        "firebase-admin": "^13.4.0",
        "helmet": "^8.1.0",
        "jsonwebtoken": "^9.0.2",
        "pg-promise": "^11.15.0",
        "redis": "^5.6.0",
        "socket.io": "^4.8.1",
        "tsx": "^4.23.0",
        "uuid": "^11.1.0"
    },
    "scripts": {
        "dev": "tsx watch index.ts",
        "start": "tsx index.ts",
        "lint": "eslint .",
        "typecheck": "tsc --noEmit",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:integration": "vitest run --config vitest.integration.config.js",
        "coverage": "vitest run --coverage && vitest run --config vitest.integration.config.js --coverage && node scripts/merge-coverage.mjs",
        "coverage:merge": "node scripts/merge-coverage.mjs",
        "migrate:up": "node-pg-migrate up",
        "migrate:down": "node-pg-migrate down",
        "migrate:redo": "node-pg-migrate redo",
        "migrate:create": "node-pg-migrate create"
    },
    "devDependencies": {
        "@eslint/js": "^9.30.1",
        "@testcontainers/postgresql": "^12.0.3",
        "@testcontainers/redis": "^12.0.3",
        "@types/bcrypt": "^6.0.0",
        "@types/cors": "^2.8.19",
        "@types/express": "^5.0.6",
        "@types/jsonwebtoken": "^9.0.10",
        "@types/node": "^26.1.0",
        "eslint": "^9.30.1",
        "globals": "^16.3.0",
        "istanbul-lib-coverage": "^3.2.2",
        "istanbul-lib-report": "^3.0.1",
        "istanbul-reports": "^3.2.0",
        "node-pg-migrate": "^8.0.3",
        "socket.io-client": "^4.8.3",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.62.1",
        "vitest": "^4.1.9"
    }
}
